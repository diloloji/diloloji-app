# Örnek ortam değişkenleri (gerekirse kopyalayıp .env yapın).
# Vite sadece VITE_ ile başlayan değişkenleri istemciye verir.

# İsteğe bağlı: Çeviri API base URL (varsayılan: MyMemory public)
# VITE_DICTIONARY_API_BASE=https://api.mymemory.translated.net/get

# İleride Firebase / Groq vb. kullanılırsa anahtarlar BURAYA alınmalı, koda yazılmamalı:
# VITE_FIREBASE_API_KEY=
# VITE_GROQ_API_KEY=

VITE_GROQ_API_KEY=***REMOVED-REVOKED-GROQ-KEY***
